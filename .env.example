# Copia este archivo como .env y completa los valores

# Base de datos PostgreSQL
DATABASE_URL=postgresql://postgres:tu_password@localhost:5432/laboratorio_seguridad

# Clave secreta para firmar tokens JWT
JWT_SECRET=cambia_esto_por_una_clave_larga_y_segura

# Clave secreta de sesión
SESSION_SECRET=otra_clave_larga_y_secreta

# Entorno
NODE_ENV=development
